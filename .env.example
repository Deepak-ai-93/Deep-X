# No AI API keys required.
# This MCP server works without any external AI provider.
# The client LLM (Claude Code, Gemini CLI, etc.) handles content generation.
#
# Optional: uncomment if you want the MCP server to generate content itself
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

DATABASE_URL=sqlite+aiosqlite:///./viral_content.db

X402_SECRET=
X402_ENABLED=false

LOG_LEVEL=INFO
ENVIRONMENT=development

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
